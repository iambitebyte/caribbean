{
  "name": "caribbean",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw 集群管理服务 - 实时监控、统一管理、智能调度",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "pnpm --filter \"./apps/**\" dev",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' build",
    "test": "pnpm --filter \"./apps/**\" test",
    "lint": "pnpm --filter \"./apps/**\" lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "init": "pnpm --filter @caribbean/server exec caribbean-server init",
    "server:start": "caribbean-server start",
    "server:stop": "caribbean-server stop",
    "server:restart": "caribbean-server restart",
    "server:status": "caribbean-server status",
    "server:logs": "caribbean-server logs",
    "agent:start": "caribbean-agent start",
    "agent:stop": "caribbean-agent stop",
    "agent:restart": "caribbean-agent restart",
    "agent:status": "caribbean-agent status",
    "agent:logs": "caribbean-agent logs"
  },
  "keywords": [
    "cluster",
    "management",
    "openclaw",
    "websocket",
    "monitoring"
  ],
  "author": "Caribbean Contributors",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@caribbean/server": "workspace:^",
    "@caribbean/agent": "workspace:^"
  }
}
